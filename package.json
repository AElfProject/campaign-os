{
  "name": "campaign-os",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "server:dev": "vite-node src/server/server.ts --listen",
    "server:migrate": "vite-node --script src/server/postgresMigrationCli.ts",
    "server:smoke": "vite-node src/server/backendRuntimeSmoke.ts --run",
    "server:start": "vite-node src/server/server.ts --listen",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run --passWithNoTests",
    "test:postgres": "vitest run src/server/postgresCampaignRuntime.integration.test.ts"
  },
  "dependencies": {
    "bullmq": "^5.79.3",
    "lucide-react": "^0.468.0",
    "pg": "^8.22.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^26.1.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vite-node": "^2.1.9",
    "vitest": "^2.1.8"
  }
}
